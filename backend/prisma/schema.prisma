// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  DOCTOR
  NURSE
  DISPATCHER
}

enum PatientStatus {
  STABLE
  OBSERVATION
  CRITICAL
  DISCHARGED
}

enum Gender {
  MALE
  FEMALE
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

enum UnitType {
  AMBULANCE
  PARAMEDIC
  HELICOPTER
  FIRE_TRUCK
  POLICE
}

enum UnitStatus {
  AVAILABLE
  EN_ROUTE
  ON_SCENE
  TRANSPORTING
  AT_HOSPITAL
  OFF_DUTY
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CallStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  ON_SCENE
  COMPLETED
  CANCELLED
}

// ==================== MODELS ====================

model Hospital {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  beds     Bed[]
  wards    Ward[]
  patients Patient[]
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  role       Role     @default(DOCTOR)
  department String
  shift      String
  status     String   @default("OFF_DUTY")
  hospitalId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hospital Hospital    @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patients Patient[]
  settings UserSettings?
}

model UserSettings {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notifications
  criticalVitalsAlerts Boolean  @default(true)
  incidentEscalations  Boolean  @default(true)
  shiftReminders       Boolean  @default(false)
  dispatchAlerts       Boolean  @default(true)
  appointmentReminders Boolean  @default(true)

  // Security & Display
  twoFactorAuth        Boolean  @default(false)
  autoLockIdleSessions Boolean  @default(true)
  compactDensity       Boolean  @default(false)

  // Display
  theme                String   @default("light")
  language             String   @default("en")
  timezone             String   @default("UTC")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model Patient {
  id            String        @id @default(uuid())
  patientCode   String        @unique
  name          String
  age           Int
  gender        Gender
  department    String
  diagnosis     String
  status        PatientStatus @default(OBSERVATION)
  admissionDate DateTime      @default(now())
  dischargeDate DateTime?
  doctorId      String?
  doctor        User?         @relation(fields: [doctorId], references: [id])
  bedId         String?       @unique
  bed           Bed?          @relation("BedPatient", fields: [bedId], references: [id])
  hospitalId    String
  hospital      Hospital      @relation(fields: [hospitalId], references: [id])
  reports       Report[]
  vitals        PatientVitals[]
  appointments  Appointment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Report {
  id         String   @id @default(uuid())
  fileName   String
  fileUrl    String
  fileType   String
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([patientId])
}

model Ward {
  id         String   @id @default(uuid())
  name       String
  floor      Int?
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  beds Bed[]
}

model Bed {
  id         String    @id @default(uuid())
  bedNumber  String
  wardId     String
  ward       Ward      @relation(fields: [wardId], references: [id], onDelete: Cascade)
  status     BedStatus @default(AVAILABLE)
  hospitalId String
  hospital   Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient    Patient?  @relation("BedPatient")

  @@unique([bedNumber, wardId])
}

model PatientVitals {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  heartRate       Int?
  systolicBP      Int?
  diastolicBP     Int?
  spO2            Float?
  temperature     Float?
  respiratoryRate Int?

  recordedAt DateTime @default(now())
  recordedBy String
  notes      String?

  isCritical Boolean @default(false)
  alertType  String?

  @@index([patientId])
  @@index([recordedAt])
  @@index([isCritical])
}

model VitalThresholds {
  id         String @id @default(uuid())
  department String
  vitalType  String

  minNormal   Float?
  maxNormal   Float?
  minCritical Float?
  maxCritical Float?

  alertEnabled Boolean @default(true)
  autoNotify   Boolean @default(false)

  @@unique([department, vitalType])
}

model Staff {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  role       String
  department String
  avatar     String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shifts       Shift[]
  appointments Appointment[]
}

model Shift {
  id         String   @id @default(uuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id])
  type       String
  startTime  DateTime
  endTime    DateTime
  department String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  scheduledAt DateTime
  type        String
  status      String   @default("SCHEDULED")
  department  String
  room        String?
  notes       String?
  duration    Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Staff   @relation(fields: [doctorId], references: [id])

  @@index([scheduledAt])
  @@index([doctorId, scheduledAt])
  @@index([patientId])
  @@index([status])
}

model Incident {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  description String?
  type        String
  severity    String
  status      String   @default("ACTIVE")
  location    String
  teams       Int      @default(1)
  progress    Int      @default(0)
  triageLevel String?
  reportedBy  String
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

model DispatchUnit {
  id          String       @id @default(uuid())
  unitCode    String       @unique
  unitType    UnitType
  status      UnitStatus   @default(AVAILABLE)
  location    String?
  eta         Int?
  department  String       @default("ER")
  crew        String[]
  currentCallId String?    @unique
  currentCall   DispatchCall? @relation("UnitCall", fields: [currentCallId], references: [id])
  lastUpdated DateTime     @updatedAt
  createdAt   DateTime     @default(now())
}

model DispatchCall {
  id           String       @id @default(uuid())
  type         String
  location     String
  priority     Priority     @default(MEDIUM)
  status       CallStatus   @default(PENDING)
  notes        String?
  assignedUnitId String?    @unique
  assignedUnit   DispatchUnit? @relation("UnitCall")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}