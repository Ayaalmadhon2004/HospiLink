datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Hospital {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users     User[]
  beds      Bed[]
  wards     Ward[] 
  patients  Patient[]
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  DISPATCHER
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(DOCTOR)
  department  String
  shift       String
  status      String   @default("OFF_DUTY")
  hospitalId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patients    Patient[]
}


model AuditLog {
  id        String   @id @default(uuid())
  action    String   
  userId    String   
  entityId  String   
  details   String?  
  createdAt DateTime @default(now())
}

enum PatientStatus {
  STABLE
  OBSERVATION
  CRITICAL
  DISCHARGED
}

enum Gender {
  MALE
  FEMALE
}

model Patient {
  id            String        @id @default(uuid())
  patientCode   String        @unique
  name          String
  age           Int
  gender        Gender
  department    String        
  diagnosis     String        
  status        PatientStatus @default(OBSERVATION)
  admissionDate DateTime      @default(now())
  dischargeDate DateTime?
  doctorId      String?
  doctor        User?         @relation(fields: [doctorId], references: [id])
  bedId         String?       @unique
  bed           Bed?          @relation("BedPatient", fields: [bedId], references: [id])
  hospitalId    String
  hospital      Hospital      @relation(fields: [hospitalId], references: [id])
  reports       Report[]      // ← NEW
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Report {
  id         String   @id @default(uuid())
  fileName   String
  fileUrl    String
  fileType   String   // PDF, JPG, PNG
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy String?  // userId
  createdAt  DateTime @default(now())
  
  @@index([patientId])
}

model Ward {
  id         String   @id @default(uuid())
  name       String   
  floor      Int?     
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  beds       Bed[]
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

model Bed {
  id          String    @id @default(uuid())
  bedNumber   String
  wardId      String
  ward        Ward      @relation(fields: [wardId], references: [id], onDelete: Cascade)
  status      BedStatus @default(AVAILABLE)
  hospitalId  String
  hospital    Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient     Patient?  @relation("BedPatient")
  
  @@unique([bedNumber, wardId]) 
}

// Vitals Monitor Models
model PatientVitals {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  
  // Vital readings
  heartRate       Int?     // BPM
  systolicBP      Int?     // mmHg
  diastolicBP     Int?     // mmHg
  spO2            Float?   // %
  temperature     Float?   // Celsius
  respiratoryRate Int?     // breaths/min
  
  // Metadata
  recordedAt  DateTime @default(now())
  recordedBy String
  notes      String?
  
  // Alerts
  isCritical Boolean @default(false)
  alertType  String? // HR_HIGH, HR_LOW, BP_HIGH, BP_LOW, SPO2_LOW, TEMP_HIGH, TEMP_LOW, RR_HIGH, RR_LOW
  
  @@index([patientId])
  @@index([recordedAt])
  @@index([isCritical])
}

model VitalThresholds {
  id          String @id @default(uuid())
  department  String
  vitalType   String // HEART_RATE, BP_SYSTOLIC, BP_DIASTOLIC, SPO2, TEMPERATURE, RESPIRATORY_RATE
  
  minNormal   Float?
  maxNormal   Float?
  minCritical Float?
  maxCritical Float?
  
  // Alert settings
  alertEnabled Boolean @default(true)
  autoNotify   Boolean @default(false)
  
  @@unique([department, vitalType])
}