// 1. تعريف المصدر والمولد
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 2. النماذج (Models)

// جدول المستشفيات
model Hospital {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users     User[]
  beds      Bed[]
  patients  Patient[]
}

// أدوار المستخدمين
enum Role {
  ADMIN
  DOCTOR
  NURSE
  DISPATCHER
}

// جدول الطواقم الطبية
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(DOCTOR)
  department  String
  shift       String
  status      String   @default("OFF_DUTY")
  hospitalId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
}

// حالات الأسرة
enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
}

// جدول الأسرة
model Bed {
  id          String    @id @default(uuid())
  bedNumber   String    @unique
  wardName    String
  status      BedStatus @default(AVAILABLE)
  hospitalId  String
  
  patient     Patient?  // علاقة مع المريض
  hospital    Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
}

// جدول المرضى
model Patient {
  id          String   @id @default(uuid())
  name        String
  age         Int
  condition   String
  admissionDate DateTime @default(now())
  
  bedId       String?  @unique // المريض لا يشغل إلا سريراً واحداً
  bed         Bed?     @relation(fields: [bedId], references: [id])
  
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
}